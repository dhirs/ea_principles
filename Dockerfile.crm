FROM node:22-bookworm-slim
WORKDIR /app

COPY hubspot/ui/package.json hubspot/ui/package-lock.json ./
RUN npm ci

COPY hubspot/ui/ ./

ENV NODE_ENV=production
ENV PORT=3001
# SUPABASE_URL / SUPABASE_KEY / CRM_SESSION_SECRET come from the runtime env
# (compose env_file). next.config.ts skips the missing ../../.env and uses them.
RUN npm run build

EXPOSE 3001
CMD ["npm", "run", "start"]
